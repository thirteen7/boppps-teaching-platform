# docker-compose 会自动连接到 MySQL 服务 `db`。
# 仅当你脱离 docker-compose 单独运行 Flask 镜像时才需设置此项。
#
# 大模型 API 配置（可选 — 首次启动容器时也可通过交互式向导配置）
# 若需要提前注入，在此取消注释并填写：
#
# 方式 A — Ollama 本地部署
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=qwen3:30b
#
# 方式 B — OpenAI 兼容 API
# LLM_PROVIDER=openai_compatible
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4

SQLALCHEMY_DATABASE_URI=mysql+pymysql://koppps:rootroot@db:3306/koppps?charset=utf8mb4
JWT_SECRET_KEY=super-secret-key
